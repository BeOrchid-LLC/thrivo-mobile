{
  "name": "thrivo-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "update:dev": "eas update --branch development",
    "update:preview": "eas update --branch preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest",
    "test:phase": "jest --testNamePattern='Phase'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'app/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'app/**/*.{ts,tsx}'",
    "checks": "npm run typecheck && npm run lint && npm run format:check"
  },
  "dependencies": {
    "@beorchid-llc/thrivo-contracts": "^0.5.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^3.9.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-async-storage-persister": "^5.51.0",
    "@tanstack/react-query": "^5.51.0",
    "@tanstack/react-query-persist-client": "^5.51.0",
    "better-auth": "^1.6.20",
    "expo": "^54",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "nativewind": "^4.2.5",
    "phosphor-react-native": "^3.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.52.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "zod": "^3.24.0",
    "zustand": "^4.5.0"

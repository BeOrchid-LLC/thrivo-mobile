    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"

{
  "expo": {
    "name": "Thrivo",
    "slug": "thrivo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d24d4616-0673-459c-9d34-ced491ef777e"
    },
    "splash": {
      "image": "./src/assets/adaptive-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beorchid.thrivo",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.beorchid.thrivo"
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Thrivo to use your camera to scan and log foods."
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#09823C"
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow Thrivo to use Face ID to unlock your saved login."
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "thrivo",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d24d4616-0673-459c-9d34-ced491ef777e"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "beorchid-llc"
  }
}

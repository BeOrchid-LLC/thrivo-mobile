{
  "expo": {
    "name": "Thrivo",
    "slug": "thrivo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beorchid.thrivo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.beorchid.thrivo"
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "scheme": "thrivo",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d24d4616-0673-459c-9d34-ced491ef777e"
      }
    },
    "owner": "beorchid-llc"
  }
}

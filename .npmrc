; better-auth's transitive `better-call` declares an OPTIONAL peer on zod@^4,
; but this app is pinned to zod@3 (shared @beorchid-llc/thrivo-contracts). The
; zod@4 features are optional and unused by the Expo auth client, so relax peer
; enforcement here. Keeps local `npm install` and EAS builds resolving the same.
legacy-peer-deps=true

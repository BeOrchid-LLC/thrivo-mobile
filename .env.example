# API
# Optional. Defaults to https://api.thrivo.fit when unset.
# EXPO_PUBLIC_API_URL=https://api.thrivo.fit

# Google OAuth client IDs. These are public client IDs, not secrets.
# Set the platform-specific value for each build target that should show Google sign-in.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Observability — REQUIRED in production builds (the app refuses to boot without
# them in a release bundle; optional in development). Both are public client keys.
# Sentry crash reporting DSN.
# EXPO_PUBLIC_SENTRY_DSN=
# PostHog product analytics. Host defaults to https://us.i.posthog.com.
# EXPO_PUBLIC_POSTHOG_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Note: native "Sign in with Apple" needs no mobile env var — the identity token's
# audience is the app bundle id. Configure APPLE_CLIENT_ID/SECRET on the backend.

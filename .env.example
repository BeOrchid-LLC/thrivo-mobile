# API
# Optional. Defaults to https://api.thrivo.fit when unset.
# EXPO_PUBLIC_API_URL=https://api.thrivo.fit

# Google OAuth client IDs. These are public client IDs, not secrets.
# Set the platform-specific value for each build target that should show Google sign-in.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

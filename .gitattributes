# Pin LF line endings for all text files so Prettier (endOfLine defaults to lf)
# and CI stay consistent regardless of the contributor's OS / git autocrlf
# setting. Without this, Windows checkouts get CRLF and `format:check` fails.
* text=auto eol=lf

# Binary assets — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.keystore binary
*.jks binary
